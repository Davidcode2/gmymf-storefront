---
import MainLayout from "../layouts/MainLayout.astro"

export const prerender = true
---

<MainLayout title="404 - GMYMF" description="This page doesn't exist. Much like our justification for these prices.">
  <section class="min-h-[80vh] flex items-center justify-center container">
    <div class="text-center">
      <p class="text-8xl md:text-[12rem] font-light text-gray-900 leading-none mb-8">
        404
      </p>
      <h1 class="heading-lg mb-8">Nothing Here</h1>
      <p class="text-muted text-body-lg mb-12 max-w-md mx-auto">
        This page doesn't exist. Much like the value proposition for a €449 hoodie made in the same factory as the €49 one.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn btn-solid">
          Escape to Safety
        </a>
        <a href="/products" class="btn">
          Browse Anyway
        </a>
      </div>
    </div>
  </section>
</MainLayout>
