---
import MainLayout from "../layouts/MainLayout.astro"
import { sdk } from "../lib/medusa"

export const prerender = false

const title = "GMYMF"
const description = "Premium overpriced essentials made in the exact same factories as everyone else. Starting at 400€ because we can."

// Fetch featured products
let featuredProducts: any[] = []
let error: string | null = null

try {
  // Get default region for price calculation
  const { regions } = await sdk.store.region.list()
  const defaultRegion = regions?.[0]
  
  // Fetch latest products
  const { products: fetchedProducts } = await sdk.store.product.list({
    limit: 6,
    ...(defaultRegion?.id && { region_id: defaultRegion.id }),
  })
  featuredProducts = fetchedProducts
} catch (err: any) {
  console.error("Failed to fetch featured products:", err)
  error = err?.message || String(err)
}
---

<MainLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="min-h-[calc(100vh-4rem)] flex flex-col justify-center container">
    <div class="max-w-5xl">
      <h1 class="heading-xl">
        Give me<br />
        your money,<br />
        fool<span class="inline-block align-text-bottom ml-1 md:ml-2">
          <img 
            src="/fool.svg" 
            alt="The Fool"
            class="w-7 h-7 md:w-12 md:h-12 inline-block"
          />
        </span>
      </h1>
      
      <div class="mt-12 flex flex-col sm:flex-row gap-4">
        <a href="/products" class="btn btn-solid">
          Give Us Money
        </a>
        <a href="/about" class="btn">
          Why So Expensive?
        </a>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:block">
      <div class="w-px h-16 bg-white/30"></div>
    </div>
  </section>
  
  <!-- Featured Section -->
  <section class="section border-t">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-muted text-sm uppercase tracking-wider mb-4">Artificial Scarcity</p>
          <h2 class="heading-lg">Limited<br />Drops</h2>
        </div>
        
        <div class="lg:pt-16">
          <p class="text-body-lg text-muted mb-8 max-w-md">
            We made 50 of these. That's it. Not because we can't make more, 
            but because limiting supply is capitalism 101 and you fell for it.
          </p>
          <a href="/products" class="btn">
            Browse The Goods
          </a>
        </div>
      </div>
      
      <!-- Product Grid Preview -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px mt-16 bg-black">
        {featuredProducts.length > 0 ? (
          featuredProducts.map((product) => {
            const image = product.images?.[0]?.url || product.thumbnail
            const cheapestVariant = product.variants?.reduce((cheapest: any, variant: any) => {
              const price = variant.calculated_price?.calculated_amount || variant.price || Infinity
              const cheapestPrice = cheapest?.calculated_price?.calculated_amount || cheapest?.price || Infinity
              return price < cheapestPrice ? variant : cheapest
            }, null)
            const hasPrice = cheapestVariant && (cheapestVariant.calculated_price?.calculated_amount || cheapestVariant.price)
            const price = hasPrice ? (cheapestVariant.calculated_price?.calculated_amount || cheapestVariant.price) : null
            
            return (
              <a href={`/products/${product.handle}`} class="card p-6 bg-black group block">
                <div class="aspect-[3/4] bg-black flex items-center justify-center mb-4 overflow-hidden">
                  {image ? (
                    <img 
                      src={image} 
                      alt={product.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-6xl font-light text-gray-800">GMYMF</span>
                  )}
                </div>
                <div class="space-y-2">
                  <h3 class="text-lg group-hover:text-muted transition-colors">
                    {product.title}
                  </h3>
                  {price ? (
                    <p class="text-muted text-sm">€{price.toFixed(2)}</p>
                  ) : (
                    <p class="text-muted text-sm">Price on request</p>
                  )}
                </div>
              </a>
            )
          })
        ) : (
          Array.from({ length: 6 }).map((_, i) => (
            <div class="card p-6 bg-black group cursor-pointer">
              <div class="aspect-[3/4] bg-gray-900 flex items-center justify-center mb-4">
                <span class="text-6xl font-light text-gray-800">{String(i + 1).padStart(2, '0')}</span>
              </div>
          <p class="text-xs uppercase tracking-wider text-muted mb-1">Coming Soon</p>
          <h3 class="text-lg">Mystery Overpriced Item</h3>
          <p class="text-muted mt-1">€449.00</p>
            </div>
          ))
        )}
      </div>
    </div>
  </section>
  
  <!-- Statement Section -->
  <section class="section border-t">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <blockquote class="heading-lg">
          "The only thing more overpriced than our hoodies is the therapy you'll need after checking your bank statement."
        </blockquote>
        <p class="text-muted text-sm uppercase tracking-wider mt-8">
          — Our Actual Philosophy
        </p>
      </div>
    </div>
  </section>
</MainLayout>
