---
import MainLayout from "../layouts/MainLayout.astro"

export const prerender = true

const title = "About - GMYMF"
const description = "The truth about GMYMF: same factories, same materials, 400% markup. But hey, the label says luxury."
---

<MainLayout title={title} description={description}>
  <!-- Hero -->
  <section class="section border-b">
    <div class="container">
      <h1 class="heading-xl max-w-5xl">
        The<br />Hustle
      </h1>
    </div>
  </section>

  <!-- Story -->
  <section class="section border-b">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <p class="text-muted text-sm uppercase tracking-wider mb-4">The Honest Truth</p>
          <h2 class="heading-md">Same Factory,<br />Different Price Tag.</h2>
        </div>
        
        <div class="lg:pt-16 space-y-6">
          <p class="text-body-lg text-muted">
            Here's the thing: your €49 hoodie and our €449 hoodie come from the 
            same factory in Bangladesh. Same sewing machines. Same cotton (probably). 
            The only difference? We convinced you that scarcity equals value.
          </p>
          <p class="text-body text-muted">
            GMYMF stands for "Give Me Your Money, Fool" — and yes, we're being 
            literal. We're not here to pretend this is about craftsmanship or 
            heritage. It's about extracting maximum value from people who want 
            to feel exclusive.
          </p>
          <p class="text-body text-muted">
            Made in Germany (designed here, at least — production is wherever 
            costs the least). Available worldwide. Price over logic. Always.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section border-b">
    <div class="container">
      <p class="text-muted text-sm uppercase tracking-wider mb-16">Our Actual Values</p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-800">
        <div class="bg-black p-8 lg:p-12">
          <p class="text-6xl font-light text-gray-800 mb-8">01</p>
          <h3 class="text-xl uppercase tracking-wider mb-4">Artificial Scarcity</h3>
          <p class="text-muted">We could make more. We choose not to. Economics 101, baby.</p>
        </div>
        
        <div class="bg-black p-8 lg:p-12">
          <p class="text-6xl font-light text-gray-800 mb-8">02</p>
          <h3 class="text-xl uppercase tracking-wider mb-4">Premium Pricing</h3>
          <p class="text-muted">If it's not at least 400€, how will anyone know you're better than them?</p>
        </div>
        
        <div class="bg-black p-8 lg:p-12">
          <p class="text-6xl font-light text-gray-800 mb-8">03</p>
          <h3 class="text-xl uppercase tracking-wider mb-4">FOMO Marketing</h3>
          <p class="text-muted">Making you panic-buy since 2026. Limited time! (It's always limited time.)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section">
    <div class="container text-center">
      <h2 class="heading-lg mb-8">Still Interested?</h2>
      <p class="text-muted text-body-lg mb-8 max-w-md mx-auto">
        Have questions about why our hoodies cost more than your monthly groceries? 
        Want to collaborate on extracting more money from consumers? We'd love to hear from you.
      </p>
      <a href="mailto:hello@gmymf.com" class="btn">
        Slide Into Our DMs
      </a>
    </div>
  </section>
</MainLayout>
